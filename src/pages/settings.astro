---
import Layout from '../layouts/Layout.astro';
import SettingsForm from '../components/SettingsForm';

const cookieValue = Astro.cookies.get('voz_session')?.value ?? '';
const hasCookies = !!cookieValue;
const cookiePreview = hasCookies ? cookieValue.substring(0, 60) + '...' : '';
---

<Layout title="Cài đặt — VOZ Reader">
  <div class="settings-page">
    <div class="page-header">
      <a href="/" class="breadcrumb">← Trang chủ</a>
      <h1 class="page-title">Cài đặt</h1>
    </div>
    <SettingsForm
      hasCookies={hasCookies}
      cookiePreview={cookiePreview}
      client:load
    />
  </div>
</Layout>
